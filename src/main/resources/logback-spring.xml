<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <property name="APP_NAME" value="homecare"/>
    <property name="LOG_DIR" value="${LOG_DIR:-logs}"/>

    <!-- ═══════════════════════════════════════════════════════════════
         Common MDC pattern (requestId, jobCorrelationId, userId, role)
         ═══════════════════════════════════════════════════════════════ -->
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] [%X{requestId:-}|%X{jobCorrelationId:-}] [%X{userId:-}|%X{role:-}] %cyan(%logger{36}) — %msg%n"/>

    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [%X{requestId:-}|%X{jobCorrelationId:-}] [%X{userId:-}|%X{role:-}] %logger{36} — %msg%n"/>

    <!-- ═══════════════════════════════════════════════════════════════
         DEV profile — coloured console only
         ═══════════════════════════════════════════════════════════════ -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${CONSOLE_PATTERN}</pattern>
            </encoder>
        </appender>

        <logger name="com.homecare" level="DEBUG"/>
        <logger name="com.homecare.core.filter" level="DEBUG"/>
        <logger name="com.homecare.core.logging" level="DEBUG"/>
        <logger name="org.springframework.web" level="INFO"/>
        <logger name="org.springframework.security" level="INFO"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="org.hibernate.type.descriptor.sql" level="TRACE"/>

        <!-- Audit logger — all audit events route here -->
        <logger name="AUDIT" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ═══════════════════════════════════════════════════════════════
         TEST profile — minimal console, no files
         ═══════════════════════════════════════════════════════════════ -->
    <springProfile name="test">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} — %msg%n</pattern>
            </encoder>
        </appender>

        <logger name="com.homecare" level="INFO"/>
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>

        <logger name="AUDIT" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ═══════════════════════════════════════════════════════════════
         PROD profile — async JSON/file appenders + error-only file
         ═══════════════════════════════════════════════════════════════ -->
    <springProfile name="prod">

        <!-- ─── Raw appenders (wrapped by async below) ──────────── -->

        <appender name="CONSOLE_RAW" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>role</includeMdcKeyName>
                <includeMdcKeyName>clientIp</includeMdcKeyName>
                <includeMdcKeyName>method</includeMdcKeyName>
                <includeMdcKeyName>uri</includeMdcKeyName>
                <includeMdcKeyName>userAgent</includeMdcKeyName>
                <includeMdcKeyName>responseStatus</includeMdcKeyName>
                <includeMdcKeyName>contentLength</includeMdcKeyName>
                <includeMdcKeyName>jobCorrelationId</includeMdcKeyName>
                <includeMdcKeyName>jobName</includeMdcKeyName>
                <includeMdcKeyName>jobGroup</includeMdcKeyName>
                <customFields>{"app":"homecare"}</customFields>
            </encoder>
        </appender>

        <appender name="JSON_FILE_RAW" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/${APP_NAME}.json</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/archive/${APP_NAME}-%d{yyyy-MM-dd}.%i.json.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>role</includeMdcKeyName>
                <includeMdcKeyName>clientIp</includeMdcKeyName>
                <includeMdcKeyName>method</includeMdcKeyName>
                <includeMdcKeyName>uri</includeMdcKeyName>
                <includeMdcKeyName>userAgent</includeMdcKeyName>
                <includeMdcKeyName>responseStatus</includeMdcKeyName>
                <includeMdcKeyName>contentLength</includeMdcKeyName>
                <includeMdcKeyName>jobCorrelationId</includeMdcKeyName>
                <includeMdcKeyName>jobName</includeMdcKeyName>
                <includeMdcKeyName>jobGroup</includeMdcKeyName>
                <customFields>{"app":"homecare"}</customFields>
            </encoder>
        </appender>

        <appender name="TEXT_FILE_RAW" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/${APP_NAME}.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/archive/${APP_NAME}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${FILE_PATTERN}</pattern>
            </encoder>
        </appender>

        <appender name="AUDIT_FILE_RAW" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/${APP_NAME}-audit.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/archive/${APP_NAME}-audit-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>2GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern>
            </encoder>
        </appender>

        <!-- ERROR-ONLY file — captures only ERROR+ for rapid incident triage -->
        <appender name="ERROR_FILE_RAW" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/${APP_NAME}-error.log</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>ERROR</level>
            </filter>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/archive/${APP_NAME}-error-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>25MB</maxFileSize>
                <maxHistory>60</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${FILE_PATTERN}</pattern>
            </encoder>
        </appender>

        <!-- ─── Async wrappers (non-blocking I/O) ──────────────── -->

        <appender name="CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>1024</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
            <includeCallerData>false</includeCallerData>
            <appender-ref ref="CONSOLE_RAW"/>
        </appender>

        <appender name="JSON_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>2048</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
            <includeCallerData>false</includeCallerData>
            <appender-ref ref="JSON_FILE_RAW"/>
        </appender>

        <appender name="TEXT_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>2048</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
            <includeCallerData>false</includeCallerData>
            <appender-ref ref="TEXT_FILE_RAW"/>
        </appender>

        <appender name="AUDIT_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>1024</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
            <includeCallerData>false</includeCallerData>
            <appender-ref ref="AUDIT_FILE_RAW"/>
        </appender>

        <appender name="ERROR_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
            <includeCallerData>true</includeCallerData>
            <appender-ref ref="ERROR_FILE_RAW"/>
        </appender>

        <!-- ─── Loggers ────────────────────────────────────────── -->

        <logger name="com.homecare" level="INFO"/>
        <logger name="com.homecare.core.logging" level="INFO"/>

        <!-- Audit logger — writes to dedicated file + console JSON -->
        <logger name="AUDIT" level="INFO" additivity="false">
            <appender-ref ref="AUDIT_FILE"/>
            <appender-ref ref="CONSOLE"/>
        </logger>

        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="JSON_FILE"/>
            <appender-ref ref="TEXT_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

</configuration>

